# Copy to `vola.env` for local Docker Compose:
#   cp vola.env.example vola.env
#   docker compose --env-file vola.env up
#
# Copy to `vola.env` for local shell development, then export it:
#   cp vola.env.example vola.env
#   set -a; source vola.env; set +a
#   go run ./cmd/vola server
#
# Copy to `~/apps/vola/config/vola.env` for production deploy:
#   mkdir -p ~/apps/vola/config
#   cp vola.env.example ~/apps/vola/config/vola.env

# Shared PostgreSQL credentials.
POSTGRES_DB=vola
POSTGRES_USER=vola
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_PORT=5432

# App runtime configuration.
PORT=8080
# Pull-only Docker deployment. Set this to the image pushed by Codeup/Flow to ACR.
# Example: crpi-ie94et80ojbqnl7z.cn-shanghai.personal.cr.aliyuncs.com/sxhx/vola:<commit-sha>
VOLA_IMAGE=
# Single-host deployment should keep Vola on a loopback-only port that does not overlap existing apps.
VOLA_HOST_PORT=18080
# Legacy deploy wrappers may still read NEUDRIVE_ENV_FILE / NEUDRIVE_HOST_PORT
# for old server scripts. New deployments should use VOLA_ENV_FILE / VOLA_HOST_PORT.
JWT_SECRET=change-this-to-a-random-secret
VAULT_MASTER_KEY=generate-with-openssl-rand-hex-32
# When PUBLIC_BASE_URL points to a non-local host, Vola refuses development defaults
# such as dev-jwt-secret-change-in-production, the bundled demo vault key, or the
# vola_dev Postgres password.
# Per-user total storage quota. Supports raw bytes or suffixes like 100MB, 1GB, 10GiB. Set to 0 to disable the limit.
USER_STORAGE_QUOTA_BYTES=100MB
# Comma-separated user UUIDs allowed to use instance-level admin APIs such as /api/admin/users and /api/ops/instance-status.
INSTANCE_ADMIN_USER_IDS=

# Binary file storage. Use db for local/dev. Use cos for Tencent Lighthouse COS / Tencent COS.
OBJECT_STORAGE_BACKEND=db
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-guangzhou
# Optional. If empty, Vola uses https://cos.<region>.myqcloud.com
TENCENT_COS_ENDPOINT=
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_PREFIX=vola
# Keep 0 for current COS buckets. Set 1 only for legacy path-style compatible buckets.
TENCENT_COS_PATH_STYLE=0
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
POCKET_ID_PROVIDER_ID=pocket
POCKET_ID_ISSUER=https://pocket-id.example.com
POCKET_ID_DISCOVERY_URL=
POCKET_ID_CLIENT_ID=your-pocket-id-client-id
POCKET_ID_CLIENT_SECRET=your-pocket-id-client-secret
POCKET_ID_SCOPES=openid profile email
GITHUB_APP_CLIENT_ID=your-github-app-client-id
GITHUB_APP_CLIENT_SECRET=your-github-app-client-secret
GITHUB_APP_SLUG=your-github-app-slug

# Local defaults. For production, set these to your public domain.
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Hosted/gateway deployments that provide /api/billing/* can enable billing UI.
# Self-hosted core deployments should keep this at 0.
VOLA_ENABLE_BILLING=0
# Empty uses the safe default: enabled for local URLs, disabled for public domains.
# Set to 1 only when public self-service signup is intentional.
VOLA_ENABLE_PUBLIC_REGISTRATION=

# Optional overrides:
# Set to 1 only when intentionally creating the bundled demo/realistic seed users and data.
# VOLA_RUN_SEED_MIGRATIONS=0
# Pocket ID notes:
# - Set POCKET_ID_ISSUER for normal OIDC discovery.
# - Or leave POCKET_ID_ISSUER empty and set POCKET_ID_DISCOVERY_URL if discovery lives at a custom URL.
# DATABASE_URL=postgres://vola:change-this-postgres-password@localhost:5432/vola?sslmode=disable
# GIT_MIRROR_HOSTED_ROOT=/var/lib/vola/git-mirrors
# CLOUDFLARED_TUNNEL_TOKEN=
# VOLA_CAPTURE_OAUTH=1
# VOLA_CAPTURE_DIR=tmp/oauth-captures

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vola",
  "version": "0.1.0",
  "identifier": "com.vola.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "node -e \"const fs=require('fs'),cp=require('child_process');const dir=fs.existsSync('web/package.json')?'web':'../web';const npm=process.platform==='win32'?'npm.cmd':'npm';const r=cp.spawnSync(npm,['run','dev'],{cwd:dir,stdio:'inherit'});process.exit(r.status??1);\"",
    "beforeBuildCommand": "node -e \"const fs=require('fs'),cp=require('child_process');const dir=fs.existsSync('web/package.json')?'web':'../web';const npm=process.platform==='win32'?'npm.cmd':'npm';const r=cp.spawnSync(npm,['run','build'],{cwd:dir,stdio:'inherit'});process.exit(r.status??1);\""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vola",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "bin/vola"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMzOTM4RTQxNDAyNDU5MUIKUldRYldTUkFRWTZUdzV4T0RiTmZaaEs2MSsyK2JQQUdRbmU3NTZkQm93Vm9kTERKQlVtY3lxWjEK",
      "endpoints": [
        "https://github.com/xiaoliuzhuan666/vola/releases/latest/download/latest.json"
      ]
    }
  }
}

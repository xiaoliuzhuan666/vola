      "restore_strategy": "manual_recreation"
    },
    {
      "source_feature": "Project chats and project memory summary",
      "vola_target": [
        "/memory/conversations/*.md",
        "/projects/<name>/...",
        "/memory/archive/*"
      ],
      "preferred_interface": [
        "HTTP:/api/import/claude-data"
      ],
      "fallback_interface": [
        "MCP:write_file",
        "MCP:save_memory"
      ],
      "current_status": "archive_or_partial_export_only",
      "restore_strategy": "manual_recreation"
    },
